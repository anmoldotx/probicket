# Server
NODE_ENV=development
PORT=3001

# Google Sheets (create a Service Account in Google Cloud Console)
# Share your spreadsheet with the service account email (Editor role)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private_key from the downloaded service account JSON
# Newlines in the key must be written as \n (literal backslash-n)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
SHEETS_SPREADSHEET_ID=your_spreadsheet_id_from_url
SHEETS_PLAYERS_TAB=Players
SHEETS_FEEDBACK_TAB=Feedback
# How long to cache the player list in memory (ms). Default: 1 hour.
PLAYER_CACHE_TTL_MS=3600000

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Session
# How long a game session lives before expiry (ms). Default: 30 minutes.
SESSION_TTL_MS=1800000

# CORS — the frontend origin allowed to call this API
ALLOWED_ORIGIN=http://localhost:3000
